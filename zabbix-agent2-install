read -p "👉 請輸入 Zabbix Server IP (例如 192.168.1.254): " ZBX_IP && \
read -p "👉 請輸入本機名稱 (例如 vps-ubuntu): " ZBX_HOST && \
echo "⏳ 開始下載並安裝套件庫..." && \
